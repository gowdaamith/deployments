pipeline{
    agent none
    environment{
        APP_NAME: "flaskapp"
        IMAGE_REPO: "flaskapp_repo/flaskapp"
        NEW_TAG: 'v${BUILD_NUMBER}'


    }
    stages{
        stage('checkout scm'){
            agent{
                docker{
                    image 'alpine/git:latest'
                }
            }
            steps{
                checkout scm

            }
        }
        stage('checkout the current deployment colour'){
            agent{
                docker {
                    image 'alpine:latest'
                    
                }

            }
            steps{
                def current=sh(
                    script: "kubectl get svc flaskapp-service -o jsonpath='{.spec.selector.version}'"
                    returnStdout: true
            
                ).trim()
                echo "Current is traffic is comming from ${current} deployment "
                if (current=="blue"){
                    env.TARGET="green"

                }else{
                    env.Target="blue"
                }
                echo "Deploying to: ${env.TARGET}"

            }
        }
        stage('build the image'){
            agent{
                docker{
                    image 'docker:24'
                    args " -v /var/run/docker.sock:/var/run/docker.sock"
                }
            }
            steps{
                sh(
                    docker built -t $IMAGE_REPO:$NEW_TAG .

                )
            }
        }
        stage('push the docker image to the repository'){
            agent{
                docker{
                    image 'docker:24'
                    args " -v /var/run/docker.sock:/var/run/docker.sock"
                }
            }
            steps{
                withCredentials([usernamePassword(credentiasId: 'docker-creds',username:'USER',password:'PASS')]){
                    sh(
                        echo $PASS | docker login -u gowdaamith --password-stdin
                        docker push $IMAGE_REPO:$NEW_TAG
                    )
                }
            }
            
        }
        stage('deploy to target'){
            agent{
                docker{
                    image 'docker:24'
                }
            }
            steps{
                withCredentials([file(credentials:'kubeconfig',variable:'KUBECONFIG')]){
                    steps(
                        script{
                            def file="k8s/${env.TARGET}-deployment.yaml"
                            sh """
                            kubectl set image deployment/flaskapp-${env.target} flaskapp=$IMAGE_REPO:$NEW_TAG
                            kubectl set version service/flaskapp-service flaskapp=$TARGET
                        }
                        

                    )
                }
            }
        }

    }

    
}